# Database (local Docker)
DATABASE_URL=postgresql://lumenhr:lumenhr_local@localhost:5432/lumenhr

# Azure / Entra ID — fill these from what you just copied
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# Microsoft Graph
GRAPH_API_ENDPOINT=https://graph.microsoft.com/v1.0

# Leave these blank for now — you'll fill them as you build
FOUNDRY_ENDPOINT=
FOUNDRY_API_KEY=
FABRIC_ENDPOINT=https://api.fabric.microsoft.com
FABRIC_WORKSPACE_ID=

# Azure Infrastructure — fill after deployment
KEY_VAULT_URL=
MCP_SERVER_URL=
AZURE_FUNCTION_APP_NAME=lumenhr-scheduler

# App
SECRET_KEY=
ENVIRONMENT=development